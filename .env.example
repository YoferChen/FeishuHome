# 飞书应用配置
# 用于博客数据预取脚本

# 飞书应用 ID
# 在飞书开放平台创建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx

# 飞书应用密钥
# 在飞书开放平台创建应用后获取
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书多维表格 ID
# 格式：app_token/table_id
# 示例：bascnxxxxxxxxxxxxxx/tblxxxxxxxxxxxxxx
# 
# 获取方式：
# 1. 打开飞书多维表格
# 2. 从 URL 中提取：https://xxx.feishu.cn/base/bascnxxxxxxxxxxxxxx?table=tblxxxxxxxxxxxxxx
# 3. 格式化为：bascnxxxxxxxxxxxxxx/tblxxxxxxxxxxxxxx
FEISHU_TABLE_ID=app_token/table_id
# 网站基础路径配置
# 用于部署到子目录（如 GitHub Pages 的项目页面）
# 默认为 '/'，如果部署到 https://username.github.io/repo-name/，则设置为 '/repo-name/'
BASE_PATH=/
