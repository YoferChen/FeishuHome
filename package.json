{
  "name": "feishu-blog-homepage",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "一个基于 Vue 3 + TypeScript + Vite 的现代化个人博客主页，集成飞书多维表格作为内容管理系统",
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "keywords": [
    "vue3",
    "typescript",
    "vite",
    "blog",
    "feishu",
    "lark",
    "tailwindcss"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/feishu-blog-homepage.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/feishu-blog-homepage/issues"
  },
  "homepage": "https://github.com/yourusername/feishu-blog-homepage#readme",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:prod": "npm run fetch-blogs && npm run build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "fetch-blogs": "tsx scripts/fetch-blogs.ts",
    "fetch-config": "tsx scripts/fetch-config.ts",
    "create-tables": "tsx scripts/create-feishu-tables.ts",
    "create-tables-user": "tsx scripts/create-with-user-auth.ts",
    "test-auth": "tsx scripts/test-user-auth.ts",
    "copy-blog-table": "tsx scripts/copy-blog-table.ts",
    "delete-tables": "tsx scripts/delete-bitable.ts",
    "add-member": "tsx scripts/add-member-to-bitable.ts",
    "add-fields-data": "tsx scripts/add-missing-fields-and-data.ts",
    "fill-data": "tsx scripts/fill-initial-data.ts",
    "print-fields": "tsx scripts/print-all-tables-fields.ts",
    "test-integration": "tsx scripts/test-data-integration.ts"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.1",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "fast-check": "^4.5.3",
    "jsdom": "^24.1.3",
    "open": "^11.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.0.6"
  }
}
